# ── Telegram (optional — falls back to console if unset) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Ollama (optional — falls back to template messages if unset) ──
# Leave OLLAMA_MODEL empty to auto-select a model from the host's specs (see /api/host).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=

# ── Audit log signing key ──
# HMAC key for the tamper-evident audit chain. The boot check REQUIRES a non-default
# value when NODE_ENV=production (otherwise the chain is forgeable). Generate a random string.
AUDIT_HMAC_SECRET=change-me-in-production

# ── Server / networking ──
PORT=3000
TICK_INTERVAL_SEC=30
# Bind address. Defaults to loopback (127.0.0.1) so the daemon isn't reachable
# off-box. To expose it (e.g. for the Android TWA over a tunnel), set HOST=0.0.0.0
# — but then AURA_API_KEY becomes REQUIRED (the daemon refuses to start otherwise).
# HOST=127.0.0.1
# Set to 1 only when behind a trusted reverse proxy/tunnel (enables X-Forwarded-For).
# AURA_TRUST_PROXY=0
# Comma-separated extra browser origins allowed via CORS (the PWA is same-origin).
# AURA_CORS_ORIGINS=https://your-frontend.example

# ── Security ──
# API key for Authorization: Bearer <key> on all /api/* requests. REQUIRED in
# production and whenever HOST is non-loopback. Empty = open (loopback dev only).
# AURA_API_KEY=your-secret-key-here

# ── Voice (optional) ──
# Set to 0 to disable voice synthesis (macOS `say` / Windows PowerShell).
# VOICE_ENABLED=1
# VOICE_NAME=Samantha

# ── Storage / demo ──
# Override the SQLite location (default data/aura.db).
# AURA_DB_PATH=data/aura.db
# Set to 1 to keep the /api/simulate demo router enabled in production (off by default).
# AURA_ENABLE_SIMULATE=0
